# HTTP listener
PORT=3000

# Admin token used as fallback if settings.json has no admin_password.
# Prefer setting admin_password via the admin /settings page after first run.
VPN_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

# (Optional) Default LLM provider for AI traffic analysis.
# Customers usually supply their own key (BYOK) from the UI.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
# LLM_BASE_URL=
